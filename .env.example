# ─────────────────────────────────────────────────────────────
#  PODIUM VIP Cards — API Keys Template
#  Copy this file to ".env" and fill in your real keys.
#  NEVER commit ".env" to version control.
# ─────────────────────────────────────────────────────────────

# ── API-Football (api-sports.io) ──────────────────────────────
# Used for: fixtures, standings, form, H2H, injuries
# Get key: https://dashboard.api-football.com/register
# Free tier: 100 calls/day | Paid: varies
API_FOOTBALL_KEY=your_api_football_key_here

# ── Football-Data.org ─────────────────────────────────────────
# Used for: league average goals per match
# Get key: https://www.football-data.org/client/register
# Free tier: 10 req/min, limited competitions (PL, PD, BL1, SA, FL1, CL)
FOOTBALL_DATA_KEY=your_football_data_key_here

# ── The Odds API ──────────────────────────────────────────────
# Used for: 1X2, Over/Under, BTTS, and corners odds
# Already in use — key from CLAUDE.md
# Get key: https://the-odds-api.com/account/
ODDS_API_KEY=your_odds_api_key_here

# ── AI Provider (Google Gemini) ───────────────────────────────
# Used for: Triple Ángulo (Narrativas de Análisis Generativo)
# Get key: https://aistudio.google.com/
# Free tier: 15 RPM, 1M TPM, 1,500 RPD
GOOGLE_API_KEY=your_google_api_key_here

# ─────────────────────────────────────────────────────────────
# ClubElo.com  → Free, no key required
# Understat.com → Free, no key required (scraping)
# ─────────────────────────────────────────────────────────────
